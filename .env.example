# Crypto Portfolio Tracker - Environment Variables 
# Copy this file to .env and add your actual keys 
 
# Ethereum Configuration 
# Get your Infura URL from: https://infura.io/ 
INFURA_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID_HERE 
 
# Get your Etherscan API key from: https://etherscan.io/apis 
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE 
